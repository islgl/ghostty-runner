				<key>script</key>
				<string>on run argv
 -- 合并所有参数（处理空格）
 set theCommand to ""
 repeat with i from 1 to length of argv
  if i &gt; 1 then
   set theCommand to theCommand &amp; " "
  end if
  set theCommand to theCommand &amp; item i of argv
 end repeat
 
 -- 启动 Ghostty
 do shell script "open -a Ghostty"
 
 -- 等待 Ghostty 激活
 delay 0.5
  -- 激活 Ghostty 窗口
 tell application "Ghostty"
  activate
 end tell
 
 delay 0.3
 
 -- 发送命令 + 回车
 tell application "System Events"
  keystroke theCommand
  keystroke return
 end tell
end run</string>
